{
  "name": "knower",
  "version": "1.0.0",
  "description": "知更 Knower - 面向个人视频创作者的本地 AI 桌面工作流客户端",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc electron/preload.ts --outDir dist-electron --module commonjs --moduleResolution node --esModuleInterop --skipLibCheck && vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "cheerio": "^1.2.0",
    "echarts-for-react": "^3.0.6",
    "gsap": "^3.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "vectra": "^0.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
